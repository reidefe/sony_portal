# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:3000/api

# Same as above, used by server-side routes (not exposed to browser)
API_BASE_URL=http://localhost:3000/api

# Resend — email delivery
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# "From" address for all outgoing emails (must be a verified sender in Resend)
RESEND_FROM=LearnHub <no-reply@yourdomain.com>

# Recipient address for contact form submissions
CONTACT_TO_EMAIL=contact@yourdomain.com

# Recipient address for support/help form submissions (falls back to CONTACT_TO_EMAIL)
SUPPORT_TO_EMAIL=support@yourdomain.com
